[global]
mouse_left_click = do_action
mouse_middle_click = close_all 
mouse_right_click = close_current
frame_color = "#458588"
frame_width = 2
separator_color= frame
highlight = "#458588"
font = JetBrainsMono Nerd Font 12
shrink = true
word_wrap = yes
padding = 15
horizontal_padding = 15
show_indicators = no

[urgency_low]
background = "#282828"
foreground = "#ebdbb2"
timeout = 3

[urgency_normal]
background = "#282828"
foreground = "#ebdbb2"
timeout = 3

[urgency_critical]
background = "#fb4934"
foreground = "#ebdbb2"
timeout = 0
